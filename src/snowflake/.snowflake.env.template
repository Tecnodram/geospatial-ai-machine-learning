# Snowflake credentials template for EY Water Quality project
# Copy this file to .snowflake.env at the project root and fill in real values.
# .snowflake.env is gitignored — never commit real credentials.

SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=SYSADMIN
